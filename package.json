{
  "name": "envoy",
  "displayName": "Envoy",
  "description": "Share .env files securely via Enclosed — end-to-end encrypted, ephemeral links inside VS Code",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "env",
    "secrets",
    "encrypted",
    "sharing",
    "enclosed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Educg550/vscode-envoy.git"
  },
  "icon": "images/icon.png",
  "publisher": "<publisher-id>",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "enclosed.shareFile",
        "title": "Share securely with Enclosed",
        "category": "Enclosed",
        "icon": "$(shield)"
      },
      {
        "command": "enclosed.openNote",
        "title": "Open Enclosed Note",
        "category": "Enclosed"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "enclosed.shareFile",
          "when": "resourceExtname == .env || resourceFilename =~ /\\.env/"
        }
      ],
      "editor/title": [
        {
          "command": "enclosed.shareFile",
          "when": "resourceExtname == .env || resourceFilename =~ /\\.env/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Enclosed",
      "properties": {
        "enclosed.instanceUrl": {
          "type": "string",
          "default": "https://enclosed.cc",
          "description": "URL of the Enclosed instance to use"
        },
        "enclosed.defaultTtl": {
          "type": "number",
          "default": 86400,
          "description": "Default TTL in seconds for new notes"
        },
        "enclosed.defaultDeleteAfterReading": {
          "type": "boolean",
          "default": true,
          "description": "Delete note after first read by default"
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all2 -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "cbor-x": "^1.6.4"
  }
}
